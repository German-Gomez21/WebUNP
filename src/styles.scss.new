/* Global styles for UNP Application */
/* This file ensures compatibility with existing CSS structure */
/* Updated: Fixed CSS duplication issue + Dark Mode Implementation */

/* Import existing main CSS */
@import 'assets/css/main.css';

/* Dark Mode CSS Variables */
:root {
  --dark-bg-primary: #333333;
  --dark-bg-secondary: #2a2a2a;
  --dark-text-primary: #ffffff;
  --dark-text-secondary: #e0e0e0;
  --dark-border: #555555;
  --dark-header-bg: #2a2a2a;
  --dark-section-gray: #2a2a2a;
}

/* Dark Mode Base Styles */
body.modo_oscuro-govco {
  background-color: var(--dark-bg-primary) !important;
  color: var(--dark-text-primary) !important;
}

body.modo_oscuro-govco,
body.modo_oscuro-govco * {
  color: var(--dark-text-primary) !important;
}

/* Light mode explicit overrides for footer (Fix for white text issue) */
body.modo_claro-govco .footer__card-container,
body.modo_claro-govco .footer__card-container * {
  color: #000000 !important;
}

body.modo_claro-govco .footer__description,
body.modo_claro-govco .footer__column-title,
body.modo_claro-govco .footer__contact-label,
body.modo_claro-govco .footer__contact-value,
body.modo_claro-govco .footer__copyright,
body.modo_claro-govco .footer__legal-link,
body.modo_claro-govco .footer__social-title,
body.modo_claro-govco .footer__link {
  color: #000000 !important;
}

body.modo_claro-govco .footer__link:hover,
body.modo_claro-govco .footer__legal-link:hover,
body.modo_claro-govco .footer__contact-value:hover {
  color: #FF6B35 !important;
}

body.modo_claro-govco .footer__contact-item .material-icons {
  color: #FF6B35 !important;
}

